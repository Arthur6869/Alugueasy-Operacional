# =============================================================
# Alugueasy MCP Server — Variáveis de ambiente (exemplo)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.
# =============================================================

# Supabase
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Caminho absoluto para o root do projeto
ALUGUEASY_PROJECT_ROOT=C:\Users\SEU_USUARIO\caminho\para\Alugueasy tarefas

# Token de autenticação do MCP
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
MCP_AUTH_TOKEN=dev-token-change-in-production

# Obsidian Local REST API
OBSIDIAN_API_KEY=sua_obsidian_api_key_aqui

# Porta do servidor (padrão: 8000)
MCP_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
